{
  "name": "api",
  "version": "1.1.0",
  "description": "Backend API service for Health Watchers healthcare management platform",
  "license": "MIT",
  "scripts": {
    "dev": "ts-node-dev --respawn -r tsconfig-paths/register src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests",
    "test:watch": "jest --watch",
    "migrate:up": "NODE_OPTIONS=\"--require ts-node/register\" migrate-mongo up",
    "migrate:down": "NODE_OPTIONS=\"--require ts-node/register\" migrate-mongo down",
    "migrate:status": "NODE_OPTIONS=\"--require ts-node/register\" migrate-mongo status",
    "migrate:create": "migrate-mongo create"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.806.0",
    "@aws-sdk/s3-request-presigner": "^3.806.0",
    "@google/generative-ai": "^0.24.1",
    "@health-watchers/config": "*",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.73.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@sentry/node": "^8.0.0",
    "@sentry/profiling-node": "^8.0.0",
    "@types/multer": "^2.1.0",
    "@types/nodemailer": "^8.0.0",
    "axios": "^1.15.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.0.0",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.0",
    "migrate-mongo": "^14.0.7",
    "mongoose": "^8.23.1",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.6",
    "otplib": "^12.0.1",
    "pdfkit": "^0.18.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prom-client": "15.1.3",
    "qrcode": "^1.5.3",
    "sharp": "^0.33.5",
    "socket.io": "^4.8.1",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/express-mongo-sanitize": "^2.0.0",
    "@types/ioredis": "^4.28.10",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/migrate-mongo": "^10.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.19.39",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.5",
    "@types/sharp": "^0.31.1",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.39.4",
    "jest": "^30.3.0",
    "mongodb-memory-server": "^10.1.4",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.9.3"
  }
}
